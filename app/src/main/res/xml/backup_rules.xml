<?xml version="1.0" encoding="utf-8"?>
<!--
   Legacy full-backup rules (Android 11 / API 30 and below).

   Backup is disabled at the manifest level (android:allowBackup="false"), so these
   rules are not active today. They are kept explicit (instead of an empty template)
   as defense-in-depth: if backup is ever re-enabled, the user's private data
   (recorded GPS tracks, favourites, saved places, settings) must still NEVER be
   uploaded to Google Drive.

   See https://developer.android.com/guide/topics/data/autobackup
-->
<full-backup-content>
    <!-- Never back up any local app data. -->
    <exclude domain="database" path="." />
    <exclude domain="sharedpref" path="." />
    <exclude domain="file" path="." />
</full-backup-content>